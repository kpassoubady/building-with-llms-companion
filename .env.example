# LLM API Keys
# Get your keys from the respective provider dashboards.
# See the book's Appendix C for detailed setup instructions.

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini - https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Anthropic Claude - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Provider selection -------------------------------------------------
# Fallback order for personal keys. Each call tries these in order and uses
# the first that succeeds, skipping any provider whose key above is unset.
# Claude has no embeddings API, so embedding calls use only gemini -> openai.
LLM_PROVIDER_PRIORITY=gemini,openai,claude

# Force a single provider (no fallback). Leave unset or set to "auto" to use
# the priority chain above. Per-exercise you can also pass provider="openai"
# or model="gpt-4o" directly to get_completion().
# LLM_PROVIDER=claude

# Set to 1 to print a note on stderr each time a provider fails and the
# chain falls through to the next one. Useful while testing your keys.
# LLM_VERBOSE=1
